# Copy to .env and fill in. Only the extraction and llm-answer features need
# a key; search, /ask extractive mode, tests and evaluation all run without it.

ANTHROPIC_API_KEY=

# Cheapest current model — minimises credit burn.
EXTRACT_MODEL=claude-haiku-4-5-20251001
ANSWER_MODEL=claude-haiku-4-5-20251001
CHUNK_SIZE=2
CHUNK_OVERLAP=1

# Retrieval
CHROMA_PATH=.chroma
COLLECTION_NAME=capital_events
TOP_K=5

# Which extracted JSON the API serves on startup (defaults to the free fixture)
EVENTS_PATH=fixtures/sample_events.json
